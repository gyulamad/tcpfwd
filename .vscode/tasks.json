{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-debug-echo",
			"type": "shell",
			"command": "./builder",
			"args": [
				"cpptools/net/examples/echo/echo.cpp",
				"--mode=debug,strict"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [{
				"base": "$gcc",
				"owner": "cpp",
				"fileLocation": "absolute",
				"pattern": {
				"regexp": "^(.*):(\\d+):(\\d+): (error|warning): (.*)$",
				"file": 1,
				"line": 2,
				"column": 3,
				"severity": 4,
				"message": 5
				}
			}]
		},
