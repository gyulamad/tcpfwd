{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-debug-echo",
			"type": "shell",
			"command": "./builder",
			"args": [
				"echo.cpp",
				"--mode=debug,strict"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-debug-hello",
			"type": "shell",
			"command": "./builder",
			"args": [
				"hello.cpp",
				"--mode=debug,strict"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-debug-proxy",
			"type": "shell",
			"command": "./builder",
			"args": [
				"proxy.cpp",
				"--mode=debug,strict"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-debug-tests",
			"type": "shell",
			"command": "./builder",
			"args": [
				"tests/tests.cpp",
				"--mode=debug,strict,test",
                "--args=\"-DTEST_SHOW_DETAILS\""
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-coverage-test",
			"type": "shell",
			"command": "./builder",
			"args": [
				"tests/tests.cpp",
				"--mode=coverage,strict,test",
                "--coverage-exclude", "\"cpptools/misc/*\"",
				// "--args=-DTEST_SERVER_PORT=9090 -DTEST_PROXY_PORT=9091",
                "--run",
                //"--run-args=\"--filter=test_TcpEchoServer\""
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-debug-misc/tests",
			"type": "shell",
			"command": "./builder",
			"args": [
				"cpptools/misc/tests/tests.cpp",
				"--mode=debug,strict,test",
                "--args=\"-DTEST_SHOW_DETAILS\""
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "build-coverage-misc/test",
			"type": "shell",
			"command": "./builder",
			"args": [
				"cpptools/misc/tests/tests.cpp",
				"--mode=coverage,strict,test",
                // "--coverage-exclude", "\"cpptools/misc/*\"",
				// "--args=-DTEST_SERVER_PORT=9090 -DTEST_PROXY_PORT=9091",
                "--run",
                //"--run-args=\"--filter=test_TcpEchoServer\""
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		}
	]
}