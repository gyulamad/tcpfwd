			],
			"preLaunchTask": "build-debug-hello",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "proxy.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/cpptools/net/examples/proxy/proxy",
			"args": [
                // "9091", "localhost:9090" // testing with hello
                "9091", "192.168.1.197:8080" // llamacpp-server
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
