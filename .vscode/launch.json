    "version": "0.2.0",
    "configurations": [
		{
			"name": "echo.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/cpptools/net/examples/echo/echo",
			"args": [
                "9090"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-echo",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "hello.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/cpptools/net/examples/hello/hello",
			"args": [
                "9090"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
