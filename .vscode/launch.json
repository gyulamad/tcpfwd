			],
			"preLaunchTask": "build-debug-proxy",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "wol-proxy.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/cpptools/net/examples/wol-proxy/wol-proxy",
			"args": [
                 // llamacpp-server
                // "9091", "192.168.1.197:8080", "192.168.1.255", "50:65:F3:2D:45:3F", "gyula", "./llamacpp-server.sh GLM-5 200000 >> llamacpp-server.log"
                "9091", 
                "192.168.1.197:8080", 
                "192.168.1.255", 
                "50:65:F3:2D:45:3F", 
                "gyula", 
                // "./llamacpp-server.sh Qwen3 200000"
                "./llamacpp-server.sh MiniMax-M2.5 100000"
                // "./llamacpp-server.sh GLM-5 200000"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-wol-proxy",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "llamacpp-wol-proxy.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/cpptools/net/examples/llamacpp-wol-proxy/llamacpp-wol-proxy",
			"args": [
                 // llamacpp-server
                // "9091", "192.168.1.197:8080", "192.168.1.255", "50:65:F3:2D:45:3F", "gyula", "./llamacpp-server.sh GLM-5 200000 >> llamacpp-server.log"
                "9091", 
                "192.168.1.197:8080", 
                "192.168.1.255", 
                "50:65:F3:2D:45:3F", 
                "gyula", 
                // "./llamacpp-server.sh Qwen3 200000"
                "./llamacpp-server.sh MiniMax-M2.5 200000"
                // "./llamacpp-server.sh GLM-5 200000"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
