{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
		{
			"name": "echo.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/echo",
			"args": [
                "9090"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-echo",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "hello.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/hello",
			"args": [
                "9090"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-hello",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "proxy.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict/proxy",
			"args": [
                // "9091", "localhost", "9090"
                "9091", "192.168.1.197", "8080" // llamacpp-server
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-proxy",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "tests.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict-test/tests/tests",
			"args": [
                //"--filter=test_TcpProxy_http_basicConnection"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-tests",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "tests.cpp (coverage)",
            "type": "node",
            "request": "attach",
			"preLaunchTask": "build-coverage-test",
		},
		{
			"name": "misc/tests.cpp (debug)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/.build/debug-strict-test/cpptools/misc/tests/tests",
			"args": [
                //"--filter=test_TcpProxy_http_basicConnection"
            ],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug-misc/tests",
			"miDebuggerPath": "/usr/bin/gdb"
		},
		{
			"name": "misc/tests.cpp (coverage)",
            "type": "node",
            "request": "attach",
			"preLaunchTask": "build-coverage-misc/test",
		},
    ]
}